<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:translateX="14"
        android:translateY="14">

        <!-- Glowing background for the icon -->
        <path
            android:pathData="M40,40m-40,0a40,40 0,1 1,80 0a40,40 0,1 1,-80 0">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:centerX="40"
                    android:centerY="40"
                    android:gradientRadius="40"
                    android:type="radial">
                    <item android:color="#443FB950" android:offset="0.0" />
                    <item android:color="#003FB950" android:offset="1.0" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Premium Emerald Icon -->
        <group
            android:translateX="15"
            android:translateY="15"
            android:scaleX="0.25"
            android:scaleY="0.25">

            <!-- Base Gem -->
            <path
                android:fillColor="#2D8A3A"
                android:pathData="M100,20 L170,60 L170,140 L100,180 L30,140 L30,60 Z" />

            <!-- Facets -->
            <path
                android:fillColor="#58D069"
                android:pathData="M100,20 L170,60 L100,100 L30,60 Z" />
            <path
                android:fillColor="#3FB950"
                android:pathData="M100,100 L170,60 L170,140 L100,180 Z" />
            <path
                android:fillColor="#1E5C26"
                android:pathData="M100,100 L30,60 L30,140 L100,180 Z" />

            <!-- Inner "M" Symbol (Minecraft/Mine) -->
            <path
                android:fillColor="#FFFFFF"
                android:fillAlpha="0.9"
                android:pathData="M70,80 L85,80 L100,105 L115,80 L130,80 L130,130 L115,130 L115,100 L100,125 L85,100 L85,130 L70,130 Z" />

            <!-- Glassy Shine -->
            <path
                android:fillColor="#FFFFFF"
                android:fillAlpha="0.2"
                android:pathData="M60,50 L100,40 L140,50 L100,60 Z" />

            <!-- Tech border -->
            <path
                android:strokeColor="#FFFFFF"
                android:strokeWidth="4"
                android:strokeAlpha="0.4"
                android:pathData="M100,20 L170,60 L170,140 L100,180 L30,140 L30,60 Z"
                android:fillColor="#00000000" />
        </group>
    </group>

</vector>
