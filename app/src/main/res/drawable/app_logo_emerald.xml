<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">

    <!-- Hexágono de fundo (Esmeralda/Bloco) -->
    <path
        android:fillColor="#3FB950"
        android:pathData="M100,20 L170,60 L170,140 L100,180 L30,140 L30,60 Z" />

    <!-- Sombreamento lateral -->
    <path
        android:fillColor="#2D8A3A"
        android:pathData="M100,100 L170,60 L170,140 L100,180 Z" />

    <!-- Topo mais claro -->
    <path
        android:fillColor="#58D069"
        android:pathData="M100,20 L170,60 L100,100 L30,60 Z" />

    <!-- Detalhes de Pixel (Estilo Minecraft) -->
    <path
        android:fillColor="#1E5C26"
        android:pathData="M60,80 h15 v15 h-15 z M120,120 h20 v20 h-20 z M80,140 h10 v10 h-10 z" />

    <!-- Borda Neon -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:pathData="M100,20 L170,60 L170,140 L100,180 L30,140 L30,60 Z"
        android:fillColor="#00000000"
        android:strokeAlpha="0.3" />

    <!-- Ícone de Importação (Seta) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M140,100 L110,70 L110,90 L80,90 L80,110 L110,110 L110,130 Z" />

</vector>
